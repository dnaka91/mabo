--- sample.kt

package sample

import java.math.BigInteger
import java.nio.ByteBuffer
import kotlin.UByte
import kotlin.UShort
import kotlin.UInt
import kotlin.ULong

import rocks.dnaka91.mabo.*
import rocks.dnaka91.mabo.buf.*

public sealed interface Sample {
    public object One : Sample, Decode, Encode, Size {
        override fun size(): Int = Sizer.sizeVariantId(1)

    }

    /**
     * Second variant
     */
    public data class Two(
        val n0: UInt,
        val n1: ULong,
    ) : Sample, Decode, Encode, Size {
        override fun size(): Int = Sizer.sizeVariantId(2)
            + Sizer.sizeField(1, { Sizer.sizeU32(this.N0) })
            + Sizer.sizeField(2, { Sizer.sizeU64(this.N1) })
            + Sizer.sizeFieldId(END_MARKER)

    }

    public data class Three(
        val field1: UInt,
        /**
         * Second field of third variant
         */
        val field2: Boolean,
    ) : Sample, Decode, Encode, Size {
        override fun size(): Int = Sizer.sizeVariantId(3)
            + Sizer.sizeField(1, { Sizer.sizeU32(this.Field1) })
            + Sizer.sizeField(2, { Sizer.sizeBool(this.Field2) })
            + Sizer.sizeFieldId(END_MARKER)

    }
}


